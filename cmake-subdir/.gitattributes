# Keep repository text files normalized while avoiding platform-specific
# automatic CRLF conversion from Git config.
* text=auto eol=lf

# Windows scripts should keep CRLF when added later.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Treat generated binaries and archives as binary.
*.exe binary
*.dll binary
*.lib binary
*.a binary
*.o binary
*.obj binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.zip binary
