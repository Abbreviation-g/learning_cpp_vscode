{
    "version": "0.2.0",
    "configurations": [
        {
            // 使用 MinGW gdb 调试 CMake 构建出的示例程序。
            "name": "Debug cmake_subdir_demo",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}\\build\\mingw\\src\\cmake_subdir_demo",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            // false 表示不打开外部控制台，cppdbg 会使用 VS Code integrated terminal。
            "externalConsole": false,
            // 允许 cpptools 为 Windows gdb 设置控制台重定向。
            "avoidWindowsConsoleRedirection": false,
            // 不自动打开 Debug Console，避免它抢到 cppdbg 终端前面。
            "internalConsoleOptions": "neverOpen",
            "logging": {
                // 程序输出交给 cppdbg integrated terminal 显示，不再镜像到 Debug Console。
                "programOutput": false
            },
            "MIMode": "gdb",
            "miDebuggerPath": "gdb",
            // 启动调试前先确保程序已经构建。
            "preLaunchTask": "CMake: build mingw",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        }
    ]
}
