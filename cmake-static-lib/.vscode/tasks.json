{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "CMake: configure (mingw)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--preset",
                "mingw"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "label": "CMake: build (mingw build)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "--preset",
                "mingwbuild"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": [
                "CMake: configure (mingw)"
            ],
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "CMake: configure (ninja-clang)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--preset",
                "ninja-clang"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "label": "CMake: build (clang build)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "--preset",
                "clangbuild"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": [
                "CMake: configure (ninja-clang)"
            ],
            "problemMatcher": [
                "$gcc"
            ]
        }
    ]
}
