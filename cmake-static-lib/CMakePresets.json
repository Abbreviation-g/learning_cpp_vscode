{
    "version": 6,
    "configurePresets": [
        {
            "name": "mingw",
            "displayName": "MinGW GCC",
            "description": "Configure the static libraries with the MinGW GCC toolchain.",
            "generator": "MinGW Makefiles",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "cacheVariables": {
                "CMAKE_CXX_COMPILER": "g++",
                "CMAKE_MAKE_PROGRAM": "mingw32-make",
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
                "CMAKE_INSTALL_PREFIX": "C:/install/cmake-static-lib"
            }
        },
        {
            "name": "ninja-clang",
            "displayName": "Ninja with Clang",
            "description": "Configure the static libraries with Ninja and Clang.",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "cacheVariables": {
                "CMAKE_CXX_COMPILER": "clang++",
                "CMAKE_MAKE_PROGRAM": "ninja",
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
                "CMAKE_INSTALL_PREFIX": "C:/install/cmake-static-lib"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "mingwbuild",
            "displayName": "Build with MinGW",
            "description": "Build the project using the mingw configure preset.",
            "configurePreset": "mingw"
        },
        {
            "name": "clangbuild",
            "displayName": "Build with Ninja/Clang",
            "description": "Build the project using the ninja-clang configure preset.",
            "configurePreset": "ninja-clang"
        }
    ]
}
