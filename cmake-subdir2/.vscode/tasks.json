{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "CMake: configure (mingw)",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--preset",
        "mingw"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "CMake: build (mingw)",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "--preset",
        "mingw"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "dependsOn": [
        "CMake: configure (mingw)"
      ],
      "problemMatcher": [
        "$gcc"
      ]
    }
  ]
}
