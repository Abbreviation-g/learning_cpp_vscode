# CMake 构建输出和缓存文件不进入仓库。
build/
cmake-build-*/
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
compile_commands.json
Makefile

# 编译生成的二进制、库文件和对象文件不进入仓库。
*.exe
*.dll
*.so
*.dylib
*.a
*.lib
*.o
*.obj

# IDE、编辑器和操作系统生成的本地文件不进入仓库。
.vs/
.vscode/*

# VS Code 的共享任务/调试配置需要提交，其他个人配置继续忽略。
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/settings.json
.idea/
*.user
*.suo
*.swp
Thumbs.db
Desktop.ini
